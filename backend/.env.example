# Django Secret Key
# Generate a new one for production: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=your-secret-key-here

# Debug mode (set to False in production)
DEBUG=True

# Allowed hosts (comma-separated, e.g., localhost,127.0.0.1,your-domain.com)
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration (Supabase PostgreSQL)
DB_NAME=postgres
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_HOST=your-db-host
DB_PORT=5432

# CORS Allowed Origins (comma-separated)
# In production, add your Vercel frontend URL
# Domain Configuration
BACKEND_DOMAIN=your-backend-domain.onrender.com
FRONTEND_DOMAIN=your-frontend-domain.vercel.app
